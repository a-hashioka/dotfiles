# --- Appearance ---
theme = TokyoNight
font-family = JetBrainsMono Nerd Font
font-size = 11
background-opacity = 1.0
adjust-cell-height = 10%

# --- Cursor ---
cursor-style = bar
cursor-style-blink = false

# --- Behavior ---
copy-on-select = true
mouse-hide-while-typing = true
shell-integration = detect

# --- Window ---
window-decoration = auto
window-padding-x = 8
window-padding-y = 8

